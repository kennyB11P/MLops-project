APP_NAME="Reviews Analytics Service"
APP_ENV="local"
API_PREFIX="/api/v1"

# Значения для запуска backend НЕ в Docker, а локально с Mac.
# PostgreSQL из Docker должен быть проброшен наружу как 5433:5432.
POSTGRES_DSN="postgresql://reviews_user:reviews_password@localhost:5433/reviews_db"

QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="wb_reviews_bge_m3"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

EMBEDDING_PROVIDER="bge_m3"
EMBEDDING_MODEL_NAME="BAAI/bge-m3"
# Для выноса embeddings в RunPod:
# EMBEDDING_PROVIDER="runpod"
# RUNPOD_API_KEY задавай только через переменную окружения shell, не храни ключ в файле.
RUNPOD_API_KEY=""
RUNPOD_ENDPOINT_ID=""
RUNPOD_BASE_URL="https://api.runpod.ai/v2"
RUNPOD_WAIT_MS="120000"
RUNPOD_EMBEDDING_INPUT_KEY="text"
CHAT_PARSER_MODE="auto"
RAG_VALIDATE_CANDIDATES="true"
RAG_VALIDATION_LIMIT="30"
