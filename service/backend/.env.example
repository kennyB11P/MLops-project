APP_NAME="Reviews Analytics Service"
APP_ENV="local"
API_PREFIX="/api/v1"

# ВАЖНО: это значения для запуска backend внутри Docker Compose.
# Контейнер api ходит к контейнеру postgres по имени сервиса postgres, а не через localhost.
POSTGRES_DSN="postgresql://reviews_user:reviews_password@postgres:5432/reviews_db"

# ВАЖНО: внутри Docker Compose Qdrant доступен по имени сервиса qdrant.
QDRANT_URL="http://qdrant:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="wb_reviews_bge_m3"

# Пока можно оставить пустым. Тогда аналитический LLM-вывод будет fallback.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5"
OPENAI_TIMEOUT_SECONDS="30"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

EMBEDDING_PROVIDER="bge_m3"
EMBEDDING_MODEL_NAME="BAAI/bge-m3"
# Для выноса embeddings в RunPod:
# EMBEDDING_PROVIDER="runpod"
# RUNPOD_API_KEY задавай только через переменную окружения хоста, не храни ключ в файле.
RUNPOD_API_KEY=""
RUNPOD_ENDPOINT_ID=""
RUNPOD_BASE_URL="https://api.runpod.ai/v2"
RUNPOD_WAIT_MS="120000"
RUNPOD_EMBEDDING_INPUT_KEY="text"
CHAT_PARSER_MODE="auto"
CHAT_PARSER_TIMEOUT_SECONDS="8"
RAG_VALIDATE_CANDIDATES="true"
RAG_VALIDATION_LIMIT="30"
RAG_EMBEDDING_TIMEOUT_SECONDS="30"
RAG_QDRANT_TIMEOUT_SECONDS="15"
RAG_VALIDATION_TIMEOUT_SECONDS="20"
RAG_KEYWORD_RESCUE_LIMIT="10"
RAG_KEYWORD_RESCUE_MAX_SCAN="1500"
RAG_WARMUP_ON_STARTUP="false"
CACHE_TTL_SECONDS="900"

DB_EXPORTS_DIR="/app/data/db_exports"
POSTGRES_EXPORT_DIR="/app/data/db_exports/postgres_reviews_bge_m3_linearsvc_saved_model"
QDRANT_EXPORT_DIR="/app/data/db_exports/qdrant_vectors_baai_bge_m3"
